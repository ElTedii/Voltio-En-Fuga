struct Light
{
	float3 direction;
	float specularPower;
	float4 ambient;
	float4 diffuse;
};

cbuffer ConstantBufferPS
{
	Light light;
};

struct VS_OUTPUT
{
	float4 Pos : SV_POSITION;
	float2 TexCoord : TEXTURE;
	float3 normal : NORMAL;
	float3 viewDirection : COORDS;
	float3 tangent : TANGENT;
	float3 binormal : BINORMAL;
	float4 vectPos : POSITION;
	float maxHeight : HEIGHT;
};

Texture2D ObjTexture : register(t0);
Texture2D ObjTexture2 : register(t1);
Texture2D ObjTexture3 : register(t2);
SamplerState ObjSamplerState : register(s0);

float4 PS( VS_OUTPUT input ) : SV_Target
{
	input.normal = normalize(input.normal);

	float4 asfalto = ObjTexture.Sample( ObjSamplerState, input.TexCoord );
	float4 hierba = ObjTexture2.Sample( ObjSamplerState, input.TexCoord );
	
	float startHeight = 0.1f;
	float blendRange = 1.0f;

	float heightFactor = saturate((input.vectPos.y - startHeight) / blendRange);

	float4 textureColor = lerp(asfalto, hierba, heightFactor);

	float3 finalColor = textureColor.rgb * light.ambient.rgb;
	finalColor += saturate(dot(light.direction, input.normal) * light.diffuse.rgb * textureColor.rgb);

	return float4(finalColor, 1.0f);
}